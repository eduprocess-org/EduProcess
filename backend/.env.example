# Copy this file to .env and fill in real values. Do NOT commit .env with real secrets.

# Database
DATABASE_URL=postgresql://<user>:<password>@<host>:<port>/<db>?pgbouncer=true

# Supabase (if used)
SUPABASE_URL=https://your-supabase-url
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# JWT secrets (use long, random, unique values)
# Generate secure secrets with e.g. `openssl rand -hex 48` or a crypto RNG.
JWT_SESSION_SECRET=your_session_secret_here_change_me
JWT_REFRESH_SECRET=your_refresh_secret_here_change_me

# Server
PORT=3000
PORT=3000

# Database
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?schema=public"
# Optional direct URL for migrations (if used)
DIRECT_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE"

# Supabase (optional — only if backend uses Supabase client)
SUPABASE_URL="https://your-project.supabase.co"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# Application secrets
JWT_SECRET="replace-with-a-secure-random-string"

# Node environment
NODE_ENV=development

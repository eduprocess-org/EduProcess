datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
}

// ==========================================
// ENUMS (CONGELADOS PARA PROTEGER AUTH)
// ==========================================
enum Role {
  student
  admin
}

enum RequestStatus {
  pending
  approved
  rejected
  in_review
}

// ==========================================
// MÓDULO ORGANIZACIONAL
// ==========================================
model Faculty {
  id             String          @id @default(uuid()) @db.Uuid
  name           String          @unique
  description    String          @db.Text
  careers        Career[]
  procedureTypes ProcedureType[]
}

model Career {
  id             String          @id @default(uuid()) @db.Uuid
  facultyId      String          @db.Uuid
  name           String
  description    String          @db.Text
  faculty        Faculty         @relation(fields: [facultyId], references: [id], onDelete: Cascade)
  profiles       Profile[]
  procedureTypes ProcedureType[]
}

// ==========================================
// MÓDULO DE IDENTIDAD Y SEGURIDAD (INTEGRO)
// ==========================================
model User {
  id                String             @id @default(uuid()) @db.Uuid
  email             String             @unique
  passwordHash      String
  firstName         String
  lastName          String
  role              Role
  createdAt         DateTime           @default(now())
  profile           Profile?
  procedureRequests ProcedureRequest[]
  observations      Observation[]
  notifications     Notification[]
  auditLogs         AuditLog[]
}

model Profile {
  id         String  @id @default(uuid()) @db.Uuid
  userId     String  @unique @db.Uuid
  careerId   String? @db.Uuid
  phone      String
  department String?
  position   String?
  user       User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  career     Career? @relation(fields: [careerId], references: [id], onDelete: SetNull)
}

// ==========================================
// MÓDULO DE TRÁMITES ACADÉMICOS
// ==========================================
model ProcedureType {
  id                   String                 @id @default(uuid()) @db.Uuid
  facultyId            String?                @db.Uuid
  careerId             String?                @db.Uuid
  name                 String
  description          String                 @db.Text
  requirementsText     String                 @db.Text
  isActive             Boolean                @default(true)
  faculty              Faculty?               @relation(fields: [facultyId], references: [id], onDelete: SetNull)
  career               Career?                @relation(fields: [careerId], references: [id], onDelete: SetNull)
  procedureRequests    ProcedureRequest[]
  procedureRequirements ProcedureRequirement[]
  procedureEmbedding   ProcedureEmbedding?
}

// Tabla 11: Requisitos atómicos (3NF)
model ProcedureRequirement {
  id              String        @id @default(uuid()) @db.Uuid
  procedureTypeId String        @db.Uuid
  name            String
  description     String        @db.Text
  isMandatory     Boolean       @default(true)
  procedureType   ProcedureType @relation(fields: [procedureTypeId], references: [id], onDelete: Cascade)
}

model ProcedureRequest {
  id                String             @id @default(uuid()) @db.Uuid
  studentId         String             @db.Uuid
  procedureTypeId   String             @db.Uuid
  status            RequestStatus      @default(pending)
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  student           User               @relation(fields: [studentId], references: [id], onDelete: Cascade)
  procedureType     ProcedureType      @relation(fields: [procedureTypeId], references: [id], onDelete: Cascade)
  uploadedDocuments UploadedDocument[]
  observations      Observation[]
  auditLogs         AuditLog[]
}

// ==========================================
// MÓDULO GESTIÓN DOCUMENTAL Y AUDITORÍA
// ==========================================

// Tabla 12: Catálogo de Tipos de Documentos
model DocumentTypeCatalog {
  id                String             @id @default(uuid()) @db.Uuid
  name              String             @unique
  uploadedDocuments UploadedDocument[]
}

model UploadedDocument {
  id         String               @id @default(uuid()) @db.Uuid
  requestId  String               @db.Uuid
  typeId     String?              @db.Uuid
  fileName   String
  fileUrl    String
  uploadedAt DateTime             @default(now())
  request    ProcedureRequest     @relation(fields: [requestId], references: [id], onDelete: Cascade)
  type       DocumentTypeCatalog? @relation(fields: [typeId], references: [id], onDelete: SetNull)
}

model Observation {
  id        String           @id @default(uuid()) @db.Uuid
  requestId String           @db.Uuid
  adminId   String           @db.Uuid
  comment   String           @db.Text
  createdAt DateTime         @default(now())
  request   ProcedureRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)
  admin     User             @relation(fields: [adminId], references: [id], onDelete: Cascade)
}

// ==========================================
// NOTIFICACIONES, IA Y AUDITORÍA GLOBAL
// ==========================================

// Tabla 13: Catálogo de Tipos de Notificaciones
model NotificationTypeCatalog {
  id            String         @id @default(uuid()) @db.Uuid
  name          String         @unique
  notifications Notification[]
}

model Notification {
  id         String                   @id @default(uuid()) @db.Uuid
  userId     String                   @db.Uuid
  typeId     String?                  @db.Uuid
  title      String
  message    String                   @db.Text
  isRead     Boolean                  @default(false)
  createdAt  DateTime                 @default(now())
  user       User                     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type       NotificationTypeCatalog? @relation(fields: [typeId], references: [id], onDelete: SetNull)
}

model ProcedureEmbedding {
  id                 String        @id @default(uuid()) @db.Uuid
  procedureTypeId    String        @unique @db.Uuid
  contentToVectorize String        @db.Text
  embeddingVector    Unsupported("vector") // Integración nativa pgvector para Supabase
  procedureType      ProcedureType @relation(fields: [procedureTypeId], references: [id], onDelete: Cascade)
}

// Tabla 14: Bitácora de Gobernancia y Auditoría
model AuditLog {
  id                 String            @id @default(uuid()) @db.Uuid
  procedureRequestId String?           @db.Uuid
  userId             String            @db.Uuid
  action             String
  oldValue           String?           @db.Text
  newValue           String?           @db.Text
  createdAt          DateTime          @default(now())
  request            ProcedureRequest? @relation(fields: [procedureRequestId], references: [id], onDelete: SetNull)
  user               User              @relation(fields: [userId], references: [id], onDelete: Restrict)
}

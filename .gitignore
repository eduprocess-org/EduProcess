## Root gitignore for monorepo

# Env files
.env
.env.*
!.env.example

# Node modules and build
node_modules/
dist/
build/

# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
pnpm-debug.log*

# Coverage
coverage/

# Editor directories and files
.vscode/
!.vscode/extensions.json
.idea/
.DS_Store

# TypeScript
*.tsbuildinfo

# OS
Thumbs.db
documents/

# Documentation (local only, exported to Word)
docs/

# MiCode local data
.mimocode/
